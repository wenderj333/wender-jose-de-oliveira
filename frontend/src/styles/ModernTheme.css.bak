/* =============================================
   SIGO COM FÉ — Tema Claro Suave (Azul Fraco + Dourado)
   ============================================= */

@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600;700&family=Inter:wght@400;500;600;700&display=swap');

:root {
  /* Backgrounds */
  --bg:       #f5f7ff;
  --bg2:      #eef1fb;
  --bg3:      #ffffff;

  /* Azul suave (não tão intenso) */
  --fb:       #4a80d4;
  --fb2:      #3568b8;
  --fb-light: #edf2fc;
  --fb-pale:  #f0f5ff;

  /* Dourado */
  --gold:     #a07820;
  --gold2:    #c49a28;
  --gold3:    #e8c040;
  --gold-bg:  #fdf8ec;
  --gold-border: #e8c04040;

  /* Texto */
  --text:     #1e2240;
  --text2:    #3d4466;
  --muted:    #7b83a6;

  /* UI */
  --border:   #e0e6f5;
  --card:     #ffffff;
  --card2:    #f7f9ff;
  --shadow:   0 2px 12px rgba(74,128,212,0.08);
  --shadow-lg:0 8px 28px rgba(74,128,212,0.14);
  --radius:   14px;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: 'Inter', system-ui, -apple-system, sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  font-size: 15px;
  -webkit-font-smoothing: antialiased;
}

/* ── TOPBAR ── */
.topbar {
  position: fixed;
  top: 0; left: 0; right: 0;
  height: 56px;
  background: linear-gradient(135deg, var(--fb2) 0%, var(--fb) 60%, #6a9ade 100%);
  display: flex;
  align-items: center;
  padding: 0 20px;
  z-index: 200;
  box-shadow: 0 2px 16px rgba(53,104,184,0.2);
}

.nav-item {
  color: rgba(255,255,255,0.92) !important;
  transition: background 0.18s;
  border-radius: 9px;
}
.nav-item:hover, .nav-item.active {
  background: rgba(255,255,255,0.18) !important;
  color: white !important;
}

.icon-btn {
  transition: opacity 0.2s, transform 0.15s;
  cursor: pointer;
}
.icon-btn:hover { opacity: 0.85; }

/* ── LAYOUT ── */
.app-container {
  padding-top: 56px;
  min-height: 100vh;
  background: var(--bg);
}

.modern-layout {
  display: grid;
  grid-template-columns: 255px 1fr 255px;
  gap: 0;
  max-width: 1180px;
  margin: 0 auto;
  padding: 16px 12px;
  min-height: calc(100vh - 56px);
  align-items: start;
}

.sidebar-left,
.sidebar-right {
  position: sticky;
  top: 70px;
  max-height: calc(100vh - 80px);
  overflow-y: auto;
  scrollbar-width: none;
}
.sidebar-left::-webkit-scrollbar,
.sidebar-right::-webkit-scrollbar { display: none; }

.sidebar-left { padding-right: 10px; }
.sidebar-right { padding-left: 10px; }

.main-content-area {
  min-width: 0;
  padding: 0 8px;
}

/* ── PROFILE CARD ── */
.profile-card-modern {
  background: linear-gradient(150deg, var(--fb2) 0%, var(--fb) 55%, #6a9ade 100%);
  border-radius: var(--radius);
  padding: 20px 16px;
  text-align: center;
  margin-bottom: 12px;
  box-shadow: var(--shadow-lg);
  position: relative;
  overflow: hidden;
}
.profile-card-modern::after {
  content: '';
  position: absolute;
  top: -10px; right: -10px;
  width: 60px; height: 60px;
  border-radius: 50%;
  background: rgba(255,255,255,0.12);
  pointer-events: none;
}

.prof-avatar {
  width: 62px;
  height: 62px;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 10px;
  border: 3px solid rgba(255,255,255,0.45);
  overflow: hidden;
  box-shadow: 0 4px 14px rgba(0,0,0,0.18);
}

.prof-name {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.05rem;
  font-weight: 700;
  color: white;
  margin-bottom: 2px;
}

.prof-stats {
  display: flex;
  justify-content: center;
  gap: 22px;
  margin-top: 12px;
  padding-top: 12px;
  border-top: 1px solid rgba(255,255,255,0.18);
}

.prof-stat-n {
  font-size: 1.05rem;
  font-weight: 700;
  color: var(--gold3);
}

.prof-stat-l {
  font-size: 0.6rem;
  color: rgba(255,255,255,0.65);
  text-transform: uppercase;
  letter-spacing: 0.07em;
}

/* ── MENU GROUPS ── */
.menu-group {
  background: var(--card);
  border-radius: var(--radius);
  padding: 10px 8px;
  margin-bottom: 10px;
  border: 1px solid var(--border);
  box-shadow: var(--shadow);
}

.menu-title {
  font-size: 0.65rem;
  font-weight: 700;
  color: var(--gold);
  text-transform: uppercase;
  letter-spacing: 0.12em;
  padding: 4px 10px 8px;
}

.menu-link {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 8px 12px;
  border-radius: 10px;
  color: var(--text2);
  text-decoration: none;
  font-size: 0.865rem;
  font-weight: 500;
  transition: all 0.18s;
  cursor: pointer;
  border: none;
  background: none;
  width: 100%;
  text-align: left;
}

.menu-link:hover {
  background: var(--fb-light);
  color: var(--fb);
}

.menu-link.active {
  background: var(--fb-light);
  color: var(--fb);
  font-weight: 600;
  border-left: 3px solid var(--fb);
}

.logout-btn {
  color: #dc2626 !important;
}
.logout-btn:hover {
  background: #fff5f5 !important;
  color: #b91c1c !important;
}

/* ── CARDS ── */
.modern-card {
  background: var(--card);
  border-radius: var(--radius);
  border: 1px solid var(--border);
  box-shadow: var(--shadow);
}

.widget-card {
  padding: 16px;
  margin-bottom: 12px;
}

/* ── MOBILE ── */
.mobile-only { display: none !important; }
.desktop-only { display: block; }

@media (max-width: 1100px) {
  .desktop-only { display: none !important; }
  .mobile-only { display: flex !important; }
  .modern-layout { grid-template-columns: 1fr; padding: 10px 8px; }
}

@media (max-width: 900px) {
  .nav-scroll { display: none !important; }
}
